NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Server-only conversation AI settings. Do not prefix these with NEXT_PUBLIC_.
CONVERSATION_PROVIDER=mock
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

# Optional: Anthropic Claude provider (used when provider is set to "anthropic")
ANTHROPIC_API_KEY=

# Optional: Google Gemini provider (used when provider is set to "google" or "gemini")
GOOGLE_API_KEY=

# Optional: ElevenLabs voice generation (leave empty to use mock/silent)
ELEVENLABS_API_KEY=
ELEVENLABS_DEFAULT_VOICE_ID=
ELEVENLABS_DEFAULT_MODEL=

# Optional: Custom conversation backend URLs (self-hosted LLM etc.)
NORMAL_CONVERSATION_BACKEND_URL=
NSFW_CONVERSATION_BACKEND_URL=

# Image generation backends
# Server-side defaults are used when app settings still say "mock".
# Use runpod or comfyui. Do not expose provider API keys with NEXT_PUBLIC_.
STANDARD_IMAGE_PROVIDER=
STANDARD_IMAGE_MODEL=
NSFW_IMAGE_PROVIDER=
NSFW_IMAGE_MODEL=
# Runpod: set provider to "runpod" in settings or STANDARD_IMAGE_PROVIDER and fill these
RUNPOD_API_KEY=
STANDARD_IMAGE_BACKEND_URL=
NSFW_IMAGE_BACKEND_URL=
# ComfyUI: set provider to "comfyui" in settings or STANDARD_IMAGE_PROVIDER and set STANDARD_IMAGE_BACKEND_URL=http://localhost:8188
